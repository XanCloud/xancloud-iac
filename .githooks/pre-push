#!/bin/sh
# Git pre-push hook: block direct pushes to main branch.
# Managed by xancloud-iac. Do not edit manually.

branch="$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')"

if [ "$branch" = "main" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════╗"
  echo "║  BLOCKED: Direct pushes to main are not allowed.   ║"
  echo "║                                                    ║"
  echo "║  Create a feature/fix/docs branch and open a PR:   ║"
  echo "║    git checkout -b docs/my-change                  ║"
  echo "║    git commit -m '...'                             ║"
  echo "║    gh pr create --title '...' --body '...'         ║"
  echo "╚══════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi
